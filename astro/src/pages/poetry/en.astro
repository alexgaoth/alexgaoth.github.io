---
// Static port of the old React page PoetryCollectionPage.jsx (lang="en").
import BaseLayout from '../../layouts/BaseLayout.astro';
import LiteraryCollection from '../../components/LiteraryCollection.astro';
import { POETRY_TEXT, buildPoetryAiPrompt, buildPoetryCopyText, buildCollectionSchema } from '../../components/literaryConfig.js';
import { APP_ROUTES, buildAppUrl } from '../../config/site.js';
import { poems } from '../../data/poetryData.js';

const lang = 'en';
const collectionSchema = buildCollectionSchema({
  name: 'Poetry by Alex Gao',
  description: 'Poetry by Alex Gao (alexgaoth).',
  url: buildAppUrl(APP_ROUTES.poetryEn),
  inLanguage: 'en',
  genre: 'poetry',
});
---

<BaseLayout
  title="Poetry — Alex Gao"
  description="Poetry by Alex Gao (alexgaoth)."
  keywords={['Alex Gao', 'alexgaoth', 'poetry', '诗', 'Chinese poetry']}
  path={APP_ROUTES.poetryEn}
  alternates={[
    { hrefLang: 'zh', href: buildAppUrl(APP_ROUTES.poetry) },
    { hrefLang: 'en', href: buildAppUrl(APP_ROUTES.poetryEn) },
    { hrefLang: 'x-default', href: buildAppUrl(APP_ROUTES.poetry) },
  ]}
  structuredData={[collectionSchema]}
>
  <LiteraryCollection
    items={poems}
    lang={lang}
    text={POETRY_TEXT[lang]}
    buildAiPrompt={buildPoetryAiPrompt}
    buildCopyText={buildPoetryCopyText}
    togglePath={APP_ROUTES.poetry}
    backPath={APP_ROUTES.art}
  />
</BaseLayout>

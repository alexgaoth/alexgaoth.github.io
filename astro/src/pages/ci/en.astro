---
// Static port of the old React page CiCollectionPage.jsx (lang="en").
import BaseLayout from '../../layouts/BaseLayout.astro';
import LiteraryCollection from '../../components/LiteraryCollection.astro';
import { CI_TEXT, buildCiAiPrompt, buildCiCopyText, buildCollectionSchema } from '../../components/literaryConfig.js';
import { APP_ROUTES, buildAppUrl } from '../../config/site.js';
import { ciPieces } from '../../data/poetryData.js';

const lang = 'en';
const collectionSchema = buildCollectionSchema({
  name: 'Ci poetry by Alex Gao',
  description: 'Ci poetry by Alex Gao (alexgaoth).',
  url: buildAppUrl(APP_ROUTES.ciEn),
  inLanguage: 'en',
  genre: 'ci poetry',
});
---

<BaseLayout
  title="Ci Poetry — Alex Gao"
  description="Ci poetry by Alex Gao (alexgaoth)."
  keywords={['Alex Gao', 'alexgaoth', 'ci poetry', '词', 'Chinese lyric poetry']}
  path={APP_ROUTES.ciEn}
  alternates={[
    { hrefLang: 'zh', href: buildAppUrl(APP_ROUTES.ci) },
    { hrefLang: 'en', href: buildAppUrl(APP_ROUTES.ciEn) },
    { hrefLang: 'x-default', href: buildAppUrl(APP_ROUTES.ci) },
  ]}
  structuredData={[collectionSchema]}
>
  <LiteraryCollection
    items={ciPieces}
    lang={lang}
    text={CI_TEXT[lang]}
    buildAiPrompt={buildCiAiPrompt}
    buildCopyText={buildCiCopyText}
    emptyState={{ title: CI_TEXT[lang].emptyTitle, text: CI_TEXT[lang].emptyText }}
    togglePath={APP_ROUTES.ci}
    backPath={APP_ROUTES.art}
  />
</BaseLayout>

---
// Static port of the old React component NavigationBar.jsx.
// Real <a href> links (crawlable), current page filtered out. The animated
// NavNowButton is rendered as a plain link until the /now island lands.
import { APP_ROUTES, NAVIGATION_ITEMS } from '../config/site.js';

const currentPath = Astro.url.pathname.replace(/\.html$/, '').replace(/\/$/, '') || '/';
const otherPages = NAVIGATION_ITEMS.filter((page) => page.path !== currentPath);
---

<nav class="navigation-bar">
  <div class="nav-back">
    <a href={APP_ROUTES.home} class="nav-back-button">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m12 19-7-7 7-7"></path><path d="M19 12H5"></path></svg>
      <span>Home</span>
    </a>
  </div>

  <div class="nav-links">
    {otherPages.map((page) =>
      page.isNowButton ? (
        <a href={page.path} class="nav-now-button">{page.label}</a>
      ) : (
        <a href={page.path} class="nav-link">{page.label}</a>
      )
    )}
  </div>
</nav>
